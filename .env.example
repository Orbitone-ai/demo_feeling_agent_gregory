# ─────────────────────────────────────────────────────────────────────────────
# VARIABLES DE ENTORNO — Agente Gregory · Feeling Vilanova Grand Marina
# Copia este archivo como .env y rellena los valores reales
# En Railway: Settings → Variables → Add Variable
# ─────────────────────────────────────────────────────────────────────────────

# ── Claude (Anthropic) ───────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── WhatsApp (Meta Business) ─────────────────────────────────────────────────
WHATSAPP_PHONE_NUMBER_ID=          # ID del número de Feeling en Meta Business
WHATSAPP_ACCESS_TOKEN=             # Token de acceso permanente
WHATSAPP_VERIFY_TOKEN=feeling_verify_secret_2024  # Debe coincidir con el campo en Meta

# ── Supabase (proyecto: Orbitone_ControlAgents) ───────────────────────────────
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_KEY=eyJhbGc...    # Service Role Key (NO la anon key)

# ── Identificación del tenant ─────────────────────────────────────────────────
# IMPORTANTE: debe ser el UUID exacto del tenant en Supabase, NO un texto libre.
# Encuéntralo con: SELECT DISTINCT tenant_id FROM brand_profiles WHERE client_name ILIKE '%feeling%';
TENANT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# ── Panel CRM ─────────────────────────────────────────────────────────────────
# Clave secreta para autenticar el panel CRM (invéntala tú, mínimo 20 caracteres)
# Acceso al panel: https://tu-url.railway.app/panel
CRM_SECRET_KEY=

# ── Notificaciones al administrador ──────────────────────────────────────────
# WhatsApp del dueño/admin para alertas de escalamiento
# Formato: código país + número sin espacios (ej: 34606162011)
OWNER_PHONE=34606162011

# ── Servidor ─────────────────────────────────────────────────────────────────
PORT=3000
TIMEZONE=Europe/Madrid
